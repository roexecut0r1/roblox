local function applyForPlayer(player)
    if player == LocalPlayer then return end
    removeHighlight(player)
    removeESPText(player)

    local char = player.Character
    if not char then return end

    local head     = char:WaitForChild("Head", 5)
    local humanoid = char:WaitForChild("Humanoid", 5)
    if not head or not humanoid then return end

    local isSpecific = specificTargets[player]
    if chamsEnabled and not isSpecific then applyHighlight(player) end
    if espEnabled and not isSpecific then
        applyHighlight(player)
        applyESPText(player)
    end
    if isSpecific then
        applyHighlight(player)
        applyESPText(player)
    end
end

local function setupPlayer(player)
    player.CharacterAdded:Connect(function()
        task.wait()
        applyForPlayer(player)
        
        -- Handle tracer updates when character respawns
        if TracersEnabled then
            updateTracerForPlayer(player)
        end
    end)
    if player.Character then
        task.spawn(function()
            applyForPlayer(player)
            
            -- Handle tracer updates for existing characters
            if TracersEnabled then
                updateTracerForPlayer(player)
            end
        end)
    end
end

