    if draggingSquare then
        local x = math.clamp(input.Position.X - square.AbsolutePosition.X, 0, square.AbsoluteSize.X)
        local y = math.clamp(input.Position.Y - square.AbsolutePosition.Y, 0, square.AbsoluteSize.Y)
        s_val = x / square.AbsoluteSize.X
        v_val = 1 - y / square.AbsoluteSize.Y
        selector.Position = UDim2.new(0, x, 0, y)
        updateColor()
    end

    if draggingHue then
        local x = math.clamp(input.Position.X - hueBar.AbsolutePosition.X, 0, hueBar.AbsoluteSize.X)
        h_val = x / hueBar.AbsoluteSize.X
        hueSelector.Position = UDim2.new(0, x, 0, 0)
        updateColor()
    end
end)

local function hexToColor3(hexValue)
    hexValue = hexValue:gsub("#", "")
    if #hexValue ~= 6 then return end
    local r = tonumber(hexValue:sub(1, 2), 16)
    local g = tonumber(hexValue:sub(3, 4), 16)
    local b = tonumber(hexValue:sub(5, 6), 16)
    if r and g and b then
        return Color3.fromRGB(r, g, b)
    end
end

hexBox.FocusLost:Connect(function()
    local c = hexToColor3(hexBox.Text)
    if c then
        h_val, s_val, v_val = Color3.toHSV(c)
        selector.Position = UDim2.new(0, s_val * square.AbsoluteSize.X, 0, (1 - v_val) * square.AbsoluteSize.Y)
        hueSelector.Position = UDim2.new(0, h_val * hueBar.AbsoluteSize.X, 0, 0)
        updateColor()
    end
end)

