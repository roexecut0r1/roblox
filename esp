local function getTeamColor(player)
    -- Check if we're in the specific game (ID: 13004241838)
    if game.PlaceId == 13004241838 then
        -- For this game, use torso color from workspace model
        local model = workspace:FindFirstChild(player.Name)
        if model then
            local bodyColors = model:FindFirstChild("Body Colors")
            if bodyColors and bodyColors:IsA("BodyColors") then
                return bodyColors.TorsoColor3
            end
        end
    else
        -- For other games, use team color system
        if player.Team then
            return customTeamColors[player.Team] or player.Team.TeamColor.Color
        else
            -- Use default color for players with no team
            return defaultESPColor
        end
    end
    
    -- Fallback to default color
    return defaultESPColor
end

