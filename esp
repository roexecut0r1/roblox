-- (Removed auto-load here; module will be loaded after embedded source is finalized)

local function snapshot_coregui()
    local t = {}
    for _,v in pairs(game:GetService("CoreGui"):GetChildren()) do t[v] = true end
    return t
end

local function diff_coregui(before)
    local added = {}
    for _,v in pairs(game:GetService("CoreGui"):GetChildren()) do
        if not before[v] then table.insert(added, v) end
    end
    return added
end

local function enable_esp()
    if esp_running then return end
    local before = snapshot_coregui()
    local ok, moduleOrErr = pcall(function()
        local f, err = loadstring(esp_code)
        if not f then error(err) end
        return f()
    end)
    if not ok then
        Rayfield:Notify({Title = "ESP", Content = "Failed to load ESP module: "..tostring(moduleOrErr), Duration = 5})
        return
    end
    esp_module = moduleOrErr
    esp_coregui_new = diff_coregui(before)
    esp_running = true
    Rayfield:Notify({Title = "ESP", Content = "ESP module loaded", Duration = 3})
end

local function disable_esp()
    if not esp_running then return end
    for _,obj in ipairs(esp_coregui_new) do pcall(function() if obj and obj.Destroy then obj:Destroy() end end) end
    -- if module exposes cleanup or disable API, call it
    pcall(function() if esp_module and esp_module.ClearSpecific then esp_module.ClearSpecific() end end)
    esp_coregui_new = {}
    esp_running = false
    Rayfield:Notify({Title = "ESP", Content = "ESP disabled", Duration = 3})
end

