RunService.RenderStepped:Connect(function()
    local myChar = LocalPlayer.Character
    local myRoot = myChar and getRoot(myChar)

    for player, highlight in pairs(highlights) do
        if highlight and highlight.Parent then
            local color = getTeamColor(player)
            highlight.FillColor    = color
            highlight.OutlineColor = color
        else
            highlights[player] = nil
        end
    end

    for player, data in pairs(billboards) do
        if not myRoot or not data.head or not data.head.Parent or not data.humanoid or not data.humanoid.Parent then
            if data.gui then
                data.gui.Enabled = false
            end
            continue
        end

        local dist = (data.head.Position - myRoot.Position).Magnitude
        if dist > MAX_DISTANCE then
            data.gui.Enabled = false
            continue
        end

        data.gui.Enabled = true
        local color = getTeamColor(player)
        data.label.Text = player.Name .. " | " .. math.floor(data.humanoid.Health) .. " | " .. math.floor(dist) .. " studs"
        data.label.TextColor3 = color
        data.label.TextSize = 14 * math.clamp(1 - (dist / 1000), 0.5, 1)
    end

    -- Update tracers
    if TracersEnabled then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                updateTracerForPlayer(player)
            end
        end
    end
end)

