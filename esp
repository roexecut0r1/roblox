-- API functions
function Esp.ToggleChams()
    -- If ESP is currently enabled, prevent enabling chams (mutual exclusivity)
    if espEnabled and not chamsEnabled then
        return chamsEnabled
    end
    chamsEnabled = not chamsEnabled
    if chamsEnabled then
        -- ensure ESP is off
        espEnabled = false
        for _,p in pairs(Players:GetPlayers()) do
            if not specificTargets[p] then
                removeESPText(p)
                applyHighlight(p)
            else
                applyHighlight(p)
                applyESPText(p)
            end
        end
    else
        for _,p in pairs(Players:GetPlayers()) do
            if not specificTargets[p] then
                removeHighlight(p)
            end
        end
    end
    return chamsEnabled
end

function Esp.ToggleESP()
    -- If chams is currently enabled, prevent enabling ESP (mutual exclusivity)
    if chamsEnabled and not espEnabled then
        return espEnabled
    end
    espEnabled = not espEnabled
    if espEnabled then
        chamsEnabled = false
        for _,p in pairs(Players:GetPlayers()) do
            if not specificTargets[p] then
                applyHighlight(p)
                applyESPText(p)
            end
        end
    else
        for _,p in pairs(Players:GetPlayers()) do
            if not specificTargets[p] then
                removeESPText(p)
                removeHighlight(p)
            end
        end
    end
    return espEnabled
end

function Esp.ToggleTracers()
    TracersEnabled = not TracersEnabled
    if not TracersEnabled then for _,line in pairs(tracerLines) do pcall(function() if line.Remove then line:Remove() elseif line.Destroy then line:Destroy() end end) end tracerLines = {} end
    return TracersEnabled
end

function Esp.CycleTracerOrigin()
    if tracerOrigin == "Center" then tracerOrigin = "Top" elseif tracerOrigin == "Top" then tracerOrigin = "Bottom" else tracerOrigin = "Center" end
    return tracerOrigin
end

function Esp.SetSpecificByName(name)
    local lname = name and name:lower()
    for _,p in pairs(Players:GetPlayers()) do if p.Name:lower():find(lname) then specificTargets[p] = true; applyHighlight(p); applyESPText(p); return p end end
    return nil
end

function Esp.ClearSpecific()
    for p in pairs(specificTargets) do removeHighlight(p); removeESPText(p); specificTargets[p] = nil end
end

function Esp.OpenPicker() openPicker() end
function Esp.SetDefaultColor(c) setDefaultColor(c) end

function Esp.IsChamsEnabled() return chamsEnabled end
function Esp.IsESPEnabled() return espEnabled end
function Esp.IsTracersEnabled() return TracersEnabled end
function Esp.GetTracerOrigin() return tracerOrigin end

return Esp
