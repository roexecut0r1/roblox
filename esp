-- Function to manage tracers for a player
local function updateTracerForPlayer(player)
    -- Use the Drawing API to draw a 2D line from the center of the screen
    -- to the player's torso. Previous implementation used LineHandleAdornment
    -- with non-existent properties and didn't render.
    if not TracersEnabled or player == LocalPlayer then
        if tracerLines[player] then
            pcall(function()
                if tracerLines[player].Remove then tracerLines[player]:Remove() end
            end)
            tracerLines[player] = nil
        end
        return
    end

    local char = player.Character
    if not char then
        if tracerLines[player] then
            pcall(function()
                if tracerLines[player].Remove then tracerLines[player]:Remove() end
            end)
            tracerLines[player] = nil
        end
        return
    end

    local rootPart = getRoot(char)
    if not rootPart then
        if tracerLines[player] then
            pcall(function()
                if tracerLines[player].Remove then tracerLines[player]:Remove() end
            end)
            tracerLines[player] = nil
        end
        return
    end

    -- Create or get the Drawing line
    local line = tracerLines[player]
    if not line then
        local ok, d = pcall(function() return Drawing and Drawing.new("Line") end)
        if ok and d then
            line = d
        else
            -- Drawing API unavailable; abort creating tracer
            return
        end
        tracerLines[player] = line
            line.Thickness = 2
        line.Transparency = 0.6
        line.Visible = true
    end

    -- Compute screen positions
    local screenPos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
    local viewportSize = Camera.ViewportSize
    local center = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)

    -- Determine origin point based on tracerOrigin setting
    local originPoint
    if tracerOrigin == "Top" then
        originPoint = Vector2.new(center.X, 0)
    elseif tracerOrigin == "Bottom" then
        originPoint = Vector2.new(center.X, viewportSize.Y)
    else
        originPoint = center
    end

    -- Hide if out of distance or not on-screen
    local dist = (Camera.CFrame.Position - rootPart.Position).Magnitude
    if dist > MAX_DISTANCE or not onScreen then
        line.Visible = false
        return
    end

    -- Determine endpoint: on-screen target
    local toPos = Vector2.new(screenPos.X, screenPos.Y)
    
    -- Parent the line to CoreGui if not already
    if not line.Parent then
        pcall(function() line.Parent = CoreGui end)
    end
    

    -- Update line endpoints and color
    line.From = originPoint
    line.To = toPos
    line.Color = getTeamColor(player)
    line.Visible = true
end

